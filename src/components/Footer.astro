---
// Footer.astro - Global Footer Component (English Redesign)
const currentYear = new Date().getFullYear();

// Section anchors live on the home page, so prefix them with "/" on other pages.
const isHome = Astro.url.pathname === '/';
const anchor = (id: string) => (isHome ? `#${id}` : `/#${id}`);
---

<footer class="main-footer">
  <div class="container footer-content">
    <div class="footer-brand">
      <a href="/" class="logo">
        <!-- Gem Pixel Logo SVG -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="logo-icon">
          <defs>
            <linearGradient id="footer-gem-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#FF6B9B" />
              <stop offset="50%" stop-color="#FF8E53" />
              <stop offset="100%" stop-color="#4ECAFF" />
            </linearGradient>
          </defs>
          <polygon points="50,15 80,45 50,85 20,45" fill="url(#footer-gem-grad)" stroke="#FFFFFF" stroke-width="4" stroke-linejoin="round"/>
          <polyline points="50,15 50,85" stroke="#FFFFFF" stroke-width="2" stroke-opacity="0.4"/>
          <polyline points="20,45 80,45" stroke="#FFFFFF" stroke-width="2" stroke-opacity="0.4"/>
          <polygon points="50,30 65,45 50,65 35,45" fill="#FFFFFF" fill-opacity="0.4"/>
          <path d="M72,20 L75,24 L79,25 L75,26 L72,30 L71,26 L67,25 L71,24 Z" fill="#FFFFFF"/>
        </svg>
        <span class="logo-text">Loef<span class="text-gradient">Studio</span></span>
      </a>
      <p class="brand-desc">
        Loef Studio develops cozy, warm, and relaxing casual mobile games that bring a splash of joy to your daily life.
      </p>
      <div class="social-links">
        <a href="#" aria-label="Twitter X" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
        </a>
        <a href="#" aria-label="Instagram" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37zM17.5 6.5h.01"/></svg>
        </a>
        <a href="#" aria-label="App Store" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </a>
      </div>
    </div>
    
    <div class="footer-links">
      <h4 class="links-title">Quick Links</h4>
      <ul>
        <li><a href={anchor('hero')}>Home</a></li>
        <li><a href={anchor('features')}>Game Features</a></li>
        <li><a href={anchor('about')}>About Us</a></li>
        <li><a href="/privacy">Privacy Policy</a></li>
      </ul>
    </div>
    
    <div class="footer-contact">
      <h4 class="links-title">Support & Contact</h4>
      <p class="contact-info">Business Inquiry: <a href="mailto:contact@loefstudio.com">contact@loefstudio.com</a></p>
      <p class="contact-info">General Support: <a href="mailto:support@loefstudio.com">support@loefstudio.com</a></p>
      <div class="cf-pages-badge">
        <span class="dot"></span> Powered by Cloudflare Pages
      </div>
    </div>
  </div>
  
  <div class="footer-bottom">
    <div class="container bottom-content">
      <p>&copy; {currentYear} Loef Studio. All rights reserved.</p>
      <div class="bottom-links">
        <a href="/privacy">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background-color: hsl(36, 30%, 94%); /* Warm muted light gray/beige */
    border-top: 1px solid var(--border-light);
    padding-top: 3.5rem;
    color: hsl(var(--text-secondary));
    font-size: 0.95rem;
    margin-top: auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3.5rem;
    padding-bottom: 3.5rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.2;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: hsl(var(--text-primary));
  }

  .logo-icon {
    width: 28px;
    height: 28px;
  }

  .logo-text {
    font-family: 'Fredoka', sans-serif;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .brand-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: hsl(var(--text-secondary));
    max-width: 320px;
    margin-top: 0.5rem;
  }

  .social-links {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.75rem;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background-color: hsl(var(--bg-card));
    border: 1px solid var(--border-light);
    border-radius: 50%;
    color: hsl(var(--text-secondary));
    transition: var(--transition-fast);
    box-shadow: 0 2px 8px rgba(180, 160, 140, 0.08);
  }

  .social-icon:hover {
    color: hsl(var(--accent-pink));
    border-color: hsl(var(--accent-pink));
    box-shadow: var(--shadow-jewel-pink);
    transform: translateY(-2px);
  }

  .links-title {
    font-family: 'Fredoka', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: hsl(var(--text-primary));
    margin-bottom: 1.2rem;
    letter-spacing: 0.02em;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .footer-links a {
    color: hsl(var(--text-secondary));
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .footer-links a:hover {
    color: hsl(var(--accent-pink));
    padding-left: 3px;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .contact-info a {
    color: hsl(var(--text-primary));
    text-decoration: none;
    transition: var(--transition-fast);
    font-weight: 600;
  }

  .contact-info a:hover {
    color: hsl(var(--accent-pink));
  }

  .cf-pages-badge {
    margin-top: 0.8rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    padding: 0.3rem 0.8rem;
    background-color: hsl(var(--bg-card));
    border: 1px solid var(--border-light);
    border-radius: 20px;
    color: hsl(var(--text-secondary));
    width: fit-content;
  }

  .cf-pages-badge .dot {
    width: 6px;
    height: 6px;
    background-color: hsl(var(--accent-mint));
    border-radius: 50%;
  }

  .footer-bottom {
    border-top: 1px solid var(--border-light);
    padding: 1.2rem 0;
    font-size: 0.85rem;
    color: hsl(var(--text-muted));
  }

  .bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .bottom-links a {
    color: hsl(var(--text-muted));
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .bottom-links a:hover {
    color: hsl(var(--text-primary));
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2.2rem;
    }
    
    .bottom-content {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
