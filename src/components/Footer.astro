---
// Footer.astro - Global Footer Component
const currentYear = new Date().getFullYear();
---

<footer class="main-footer">
  <div class="container footer-content">
    <div class="footer-brand">
      <a href="/" class="logo">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="logo-icon">
          <defs>
            <linearGradient id="footer-logo-grad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#00ffff" />
              <stop offset="100%" stop-color="#b545ff" />
            </linearGradient>
          </defs>
          <polygon points="50,8 88,30 88,70 50,92 12,70 12,30" stroke="url(#footer-logo-grad)" stroke-width="4" stroke-linejoin="round" fill="none"/>
          <path d="M38,30 L38,70 L62,70" stroke="url(#footer-logo-grad)" stroke-width="6" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M38,30 L58,30" stroke="url(#footer-logo-grad)" stroke-width="6" stroke-linecap="round"/>
          <path d="M38,48 L54,48" stroke="url(#footer-logo-grad)" stroke-width="6" stroke-linecap="round"/>
        </svg>
        <span class="logo-text">LOEF<span class="text-gradient">STUDIO</span></span>
      </a>
      <p class="brand-desc">
        LOEF Studio는 한계를 극복하고 상상 이상의 세계를 게임으로 구현해내는 독립 게임 개발 스튜디오입니다.
      </p>
      <div class="social-links">
        <a href="#" aria-label="Twitter X" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
        </a>
        <a href="#" aria-label="YouTube" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
        </a>
        <a href="#" aria-label="Discord" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8M12 8v8"/></svg>
        </a>
      </div>
    </div>
    
    <div class="footer-links">
      <h4 class="links-title">Quick Links</h4>
      <ul>
        <li><a href="#hero">Home</a></li>
        <li><a href="#games">Featured Games</a></li>
        <li><a href="#about">About the Studio</a></li>
        <li><a href="#careers">Careers</a></li>
      </ul>
    </div>
    
    <div class="footer-contact">
      <h4 class="links-title">Get in Touch</h4>
      <p class="contact-info">비즈니스 문의: <a href="mailto:contact@loefstudio.com">contact@loefstudio.com</a></p>
      <p class="contact-info">채용 문의: <a href="mailto:recruit@loefstudio.com">recruit@loefstudio.com</a></p>
      <div class="cf-pages-badge">
        <span class="dot"></span> Powered by Cloudflare Pages
      </div>
    </div>
  </div>
  
  <div class="footer-bottom">
    <div class="container bottom-content">
      <p>&copy; {currentYear} LOEF Studio. All rights reserved.</p>
      <div class="bottom-links">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    background-color: hsl(240, 15%, 4%);
    border-top: 1px solid var(--border-light);
    padding-top: 4rem;
    color: hsl(var(--text-secondary));
    font-size: 0.9rem;
    margin-top: auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 4rem;
    padding-bottom: 4rem;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: hsl(var(--text-primary));
  }

  .logo-icon {
    width: 32px;
    height: 32px;
  }

  .logo-text {
    font-family: 'Outfit', sans-serif;
    font-size: 1.25rem;
    font-weight: 900;
    letter-spacing: 0.05em;
  }

  .brand-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: hsl(var(--text-muted));
    max-width: 320px;
  }

  .social-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .social-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background-color: hsla(240, 10%, 15%, 0.6);
    border: 1px solid var(--border-light);
    border-radius: 50%;
    color: hsl(var(--text-secondary));
    transition: var(--transition-fast);
  }

  .social-icon:hover {
    color: hsl(var(--neon-cyan));
    border-color: hsl(var(--neon-cyan));
    box-shadow: var(--shadow-neon-cyan);
    transform: translateY(-2px);
  }

  .links-title {
    font-family: 'Outfit', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: hsl(var(--text-primary));
    margin-bottom: 1.5rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .footer-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    color: hsl(var(--text-secondary));
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .footer-links a:hover {
    color: hsl(var(--neon-cyan));
    padding-left: 4px;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-info a {
    color: hsl(var(--text-primary));
    text-decoration: none;
    transition: var(--transition-fast);
    font-weight: 500;
  }

  .contact-info a:hover {
    color: hsl(var(--neon-purple));
  }

  .cf-pages-badge {
    margin-top: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    padding: 0.35rem 0.75rem;
    background-color: hsla(200, 100%, 50%, 0.08);
    border: 1px solid rgba(0, 172, 238, 0.2);
    border-radius: 20px;
    color: #00acee;
    width: fit-content;
  }

  .cf-pages-badge .dot {
    width: 6px;
    height: 6px;
    background-color: #00acee;
    border-radius: 50%;
    box-shadow: 0 0 6px #00acee;
  }

  .footer-bottom {
    border-top: 1px solid var(--border-light);
    padding: 1.5rem 0;
    font-size: 0.8rem;
    color: hsl(var(--text-muted));
  }

  .bottom-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .bottom-links a {
    color: hsl(var(--text-muted));
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .bottom-links a:hover {
    color: hsl(var(--text-primary));
  }

  @media (max-width: 768px) {
    .footer-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    
    .bottom-content {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
