---
interface Props {
  title: string;
  genre: string;
  image: string;
  description: string;
  platforms: string[];
  status: string;
  link: string;
}

const { title, genre, image, description, platforms, status, link } = Astro.props;
---

<div class="game-card glass">
  <div class="image-wrapper">
    <img src={image} alt={`${title} cover art`} loading="lazy" />
    <span class={`status-badge ${status.toLowerCase().replace(/\s+/g, '-')}`}>
      {status}
    </span>
  </div>
  
  <div class="card-content">
    <span class="genre">{genre}</span>
    <h3 class="title">{title}</h3>
    <p class="desc">{description}</p>
    
    <div class="card-footer">
      <div class="platforms">
        {platforms.map(platform => (
          <span class="platform-badge">{platform}</span>
        ))}
      </div>
      <a href={link} class="btn-detail">
        View Project
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  .game-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    transition: transform var(--transition-normal), border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .game-card:hover {
    transform: translateY(-8px);
    border-color: hsl(var(--neon-cyan));
    box-shadow: var(--shadow-neon-cyan);
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid var(--border-light);
  }

  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-normal);
  }

  .game-card:hover .image-wrapper img {
    transform: scale(1.08);
  }

  .status-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .status-badge.in-development {
    background-color: hsla(var(--neon-purple), 0.2);
    border: 1px solid hsl(var(--neon-purple));
    color: hsl(var(--neon-purple));
  }

  .status-badge.released {
    background-color: hsla(var(--neon-cyan), 0.2);
    border: 1px solid hsl(var(--neon-cyan));
    color: hsl(var(--neon-cyan));
  }

  .card-content {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    padding: 1.5rem;
  }

  .genre {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    color: hsl(var(--neon-purple));
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .title {
    font-size: 1.5rem;
    font-weight: 800;
    margin-bottom: 0.75rem;
    transition: color var(--transition-fast);
  }

  .game-card:hover .title {
    color: hsl(var(--neon-cyan));
  }

  .desc {
    font-size: 0.9rem;
    color: hsl(var(--text-secondary));
    line-height: 1.5;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    border-top: 1px solid var(--border-light);
    padding-top: 1rem;
  }

  .platforms {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .platform-badge {
    font-size: 0.7rem;
    padding: 0.15rem 0.4rem;
    background-color: hsla(240, 10%, 20%, 0.6);
    border: 1px solid var(--border-light);
    border-radius: 3px;
    color: hsl(var(--text-secondary));
    font-weight: 600;
  }

  .btn-detail {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: hsl(var(--text-primary));
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .btn-detail svg {
    transition: transform var(--transition-fast);
  }

  .btn-detail:hover {
    color: hsl(var(--neon-cyan));
  }

  .btn-detail:hover svg {
    transform: translateX(4px);
  }
</style>
