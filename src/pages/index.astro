---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />

  <!-- Hero Section -->
  <section id="hero" class="hero-section">
    <div class="hero-bg-sparkles"></div>
    <div class="container hero-grid fade-in">
      <div class="hero-text-panel">
        <span class="hero-badge">Sparkling Puzzle Game</span>
        <h1 class="hero-title">Diamond<br><span class="text-gradient">Dot Art</span></h1>
        <p class="hero-desc">
          Bring a splash of sparkle and cozy relaxation to your daily life. Complete your own shiny gem paintings bead by bead! Charming pixel templates, ASMR sounds, and comfortable touch gameplay are coming soon to your iPhone.
        </p>
        
        <div class="hero-actions">
          <div class="coming-soon-badge">
            <span class="pulse-dot"></span> Coming Soon on the App Store
          </div>
        </div>
      </div>
      
      <div class="hero-image-panel">
        <div class="device-mockup">
          <img src="/images/diamond-game-preview.png" alt="Diamond Dot Art game preview on iPhone" class="preview-img" />
          <div class="glow-effect"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section id="features" class="features-section reveal-section">
    <div class="container">
      <div class="section-header">
        <span class="subtitle">GAME FEATURES</span>
        <h2 class="section-title">Sparkling Moments of <span class="text-gradient">Relaxation</span></h2>
        <div class="section-line"></div>
      </div>
      
      <div class="features-grid">
        <div class="cozy-card feature-card">
          <div class="feature-icon pink">💎</div>
          <h3>Vibrant Diamond Beads</h3>
          <p>We bring the physical beauty of sparkling crystal gems straight to your screen with a simple and satisfying tap.</p>
        </div>
        
        <div class="cozy-card feature-card">
          <div class="feature-icon blue">🎧</div>
          <h3>Calming ASMR Sound</h3>
          <p>Gentle tap sounds and delicate haptic feedback wash away your daily stress as you craft your masterpiece bead by bead.</p>
        </div>
        
        <div class="cozy-card feature-card">
          <div class="feature-icon yellow">🎨</div>
          <h3>Cute & Cozy Templates</h3>
          <p>Unlimited free templates, ranging from adorable kittens and puppies to beautiful, relaxing landscape designs.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="about-section reveal-section">
    <div class="container">
      <div class="about-card glass">
        <div class="about-content">
          <span class="subtitle">ABOUT THE STUDIO</span>
          <h2 class="section-title">Tiny Sparkles, <span class="text-gradient">Great Happiness</span></h2>
          <p class="about-desc">
            Loef Studio develops cozy, warm, and relaxing casual mobile puzzle games for players around the world. 
          </p>
          <p class="about-desc">
            We exclude stressful, competitive features. Instead, we aim to create warm, well-made games that you can comfortably play at the end of a long day, lying in bed with the lights down.
          </p>
        </div>
        <div class="about-brand-visual">
          <div class="brand-box">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" class="brand-logo-svg">
              <defs>
                <linearGradient id="about-gem-grad" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#FF6B9B" />
                  <stop offset="100%" stop-color="#4ECAFF" />
                </linearGradient>
              </defs>
              <polygon points="50,15 80,45 50,85 20,45" fill="url(#about-gem-grad)" stroke="#FFFFFF" stroke-width="4" stroke-linejoin="round"/>
              <polyline points="50,15 50,85" stroke="#FFFFFF" stroke-width="2" stroke-opacity="0.4"/>
              <polyline points="20,45 80,45" stroke="#FFFFFF" stroke-width="2" stroke-opacity="0.4"/>
              <path d="M72,20 L75,24 L79,25 L75,26 L72,30 L71,26 L67,25 L71,24 Z" fill="#FFFFFF"/>
            </svg>
            <span class="brand-text">Loef Studio</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="contact-section reveal-section">
    <div class="container contact-container cozy-card">
      <div class="contact-info-panel">
        <span class="subtitle">GET IN TOUCH</span>
        <h2 class="section-title">Let's <span class="text-gradient">Connect</span></h2>
        <p class="contact-text">
          We welcome project inquiries, publisher discussions, and general collaboration. Reach out to us via email or use the form.
        </p>
        <div class="contact-details">
          <div class="detail-item">
            <span class="icon">📧</span>
            <div>
              <h4>Email Inquiry</h4>
              <p>contact@loefstudio.com</p>
            </div>
          </div>
          <div class="detail-item">
            <span class="icon">📍</span>
            <div>
              <h4>Studio Location</h4>
              <p>Seoul, Republic of Korea</p>
            </div>
          </div>
        </div>
      </div>
      
      <form class="contact-form" id="contactForm">
        <div class="form-group">
          <label for="name">Name / Company</label>
          <input type="text" id="name" required placeholder="Enter your name or company." />
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input type="email" id="email" required placeholder="Enter your email address." />
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" rows="5" required placeholder="How can we help you? Feel free to write details here."></textarea>
        </div>
        <button type="submit" class="btn-primary form-submit">Send Message</button>
      </form>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Hero Section Styling - Cozy Clean Light */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: radial-gradient(circle at 10% 20%, rgba(255, 107, 155, 0.06) 0%, rgba(78, 202, 255, 0.05) 50%, hsl(var(--bg-cream)) 100%);
    padding-top: 100px;
    padding-bottom: 50px;
    overflow: hidden;
  }

  .hero-bg-sparkles {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(hsla(var(--accent-yellow), 0.3) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    opacity: 0.5;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 2;
  }

  .hero-text-panel {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .hero-badge {
    font-size: 0.9rem;
    font-weight: 700;
    padding: 0.35rem 1rem;
    background-color: hsla(var(--accent-pink), 0.1);
    color: hsl(var(--accent-pink));
    border-radius: 20px;
    font-family: 'Fredoka', sans-serif;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.2rem);
    font-weight: 700;
    line-height: 1.15;
    color: hsl(var(--text-primary));
  }

  .hero-desc {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.8;
    color: hsl(var(--text-secondary));
  }

  .hero-actions {
    margin-top: 0.5rem;
  }

  .coming-soon-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.6rem;
    background-color: hsl(var(--bg-card));
    border: 1px solid var(--border-light);
    border-radius: 30px;
    color: hsl(var(--text-secondary));
    font-family: 'Fredoka', sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    box-shadow: var(--shadow-soft);
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    background-color: hsl(var(--accent-pink));
    border-radius: 50%;
    animation: pulse 1.8s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 107, 155, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(255, 107, 155, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 107, 155, 0); }
  }

  /* Mockup Layout */
  .hero-image-panel {
    display: flex;
    justify-content: center;
    position: relative;
  }

  .device-mockup {
    position: relative;
    width: 100%;
    max-width: 320px;
    border-radius: 40px;
    padding: 8px;
    background: #ffffff;
    box-shadow: 0 20px 50px rgba(180, 160, 140, 0.25);
    border: 1px solid var(--border-light);
    transform: rotate(2deg);
    transition: var(--transition-normal);
  }

  .device-mockup:hover {
    transform: rotate(0deg) scale(1.03);
  }

  .preview-img {
    width: 100%;
    height: auto;
    border-radius: 32px;
    display: block;
    object-fit: cover;
  }

  .glow-effect {
    position: absolute;
    top: -10%;
    left: -10%;
    width: 120%;
    height: 120%;
    background: radial-gradient(circle, rgba(255, 94, 145, 0.15) 0%, transparent 60%);
    z-index: -1;
    pointer-events: none;
  }

  /* Sections Header */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .subtitle {
    font-size: 0.85rem;
    font-weight: 700;
    color: hsl(var(--accent-pink));
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.5rem;
    font-family: 'Fredoka', sans-serif;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.5rem);
    font-weight: 700;
    margin-bottom: 0.8rem;
  }

  .section-line {
    width: 45px;
    height: 4px;
    background: var(--gradient-jewel);
    margin: 0 auto;
    border-radius: 2px;
  }

  .section-line.left {
    margin: 0 0 1.2rem 0;
  }

  .section-desc {
    max-width: 580px;
    margin: 1.2rem auto 0 auto;
    color: hsl(var(--text-secondary));
    font-size: 0.98rem;
  }

  /* Features Section */
  .features-section {
    padding: 6rem 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2.2rem;
  }

  .feature-card {
    padding: 2.5rem 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .feature-icon {
    font-size: 2.2rem;
    width: 64px;
    height: 64px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-soft);
  }

  .feature-icon.pink { background-color: hsla(var(--accent-pink), 0.08); }
  .feature-icon.blue { background-color: hsla(var(--accent-blue), 0.08); }
  .feature-icon.yellow { background-color: hsla(var(--accent-yellow), 0.08); }

  .feature-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .feature-card p {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* About Section */
  .about-section {
    padding: 6rem 0;
    background-color: hsl(36, 40%, 96%); /* Muted warm background */
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .about-card {
    padding: 3.5rem;
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    gap: 4rem;
    align-items: center;
    background: hsl(var(--bg-card));
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .about-desc {
    font-size: 1rem;
    line-height: 1.8;
  }

  .about-brand-visual {
    display: flex;
    justify-content: center;
  }

  .brand-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    padding: 2rem;
    border: 2px dashed rgba(255, 94, 145, 0.25);
    border-radius: var(--radius-lg);
    background-color: hsla(var(--bg-cream), 0.5);
  }

  .brand-logo-svg {
    width: 64px;
    height: 64px;
    filter: drop-shadow(0 4px 10px rgba(255, 107, 155, 0.25));
  }

  .brand-text {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: hsl(var(--text-primary));
  }

  /* Contact Section */
  .contact-section {
    padding: 6rem 0;
    background-color: hsl(36, 40%, 98%);
  }

  .contact-container {
    display: grid;
    grid-template-columns: 1.2fr 1.8fr;
    gap: 3.5rem;
    padding: 3.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .contact-info-panel {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .contact-text {
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  .detail-item {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .detail-item .icon {
    font-size: 1.4rem;
    width: 44px;
    height: 44px;
    background-color: hsla(240, 10%, 15%, 0.03);
    border: 1px solid var(--border-light);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .detail-item h4 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.15rem;
  }

  .detail-item p {
    font-size: 0.9rem;
    color: hsl(var(--text-secondary));
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .form-group label {
    font-family: 'Fredoka', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    color: hsl(var(--text-secondary));
  }

  .form-group input,
  .form-group textarea {
    padding: 0.8rem 1.1rem;
    background-color: hsl(var(--bg-cream));
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    color: hsl(var(--text-primary));
    font-family: inherit;
    font-size: 0.95rem;
    transition: var(--transition-fast);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: hsl(var(--accent-pink));
    box-shadow: 0 0 10px hsla(var(--accent-pink), 0.15);
  }

  .form-submit {
    align-self: flex-start;
  }

  @media (max-width: 992px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
      text-align: center;
    }
    
    .hero-text-panel {
      align-items: center;
    }
    
    .contact-container {
      grid-template-columns: 1fr;
      padding: 2rem;
    }
    
    .about-card {
      grid-template-columns: 1fr;
      padding: 2.2rem;
      gap: 2.5rem;
    }
  }

  /* Scroll Reveal Setup */
  .reveal-section {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .reveal-section.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Simple intersection observer for scroll reveal effects
  const revealSections = document.querySelectorAll('.reveal-section');
  
  const observerOptions = {
    root: null,
    threshold: 0.12,
    rootMargin: "0px 0px -40px 0px"
  };

  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        obs.unobserve(entry.target);
      }
    });
  }, observerOptions);

  revealSections.forEach(section => {
    observer.observe(section);
  });

  // Mock Form Submit
  const contactForm = document.getElementById('contactForm');
  contactForm?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Thank you! Your message has been sent successfully. We will get back to you shortly.');
    (contactForm as HTMLFormElement).reset();
  });
</script>
