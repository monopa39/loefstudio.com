---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import GameCard from '../components/GameCard.astro';
import Footer from '../components/Footer.astro';

// Game data
const featuredGames = [
  {
    title: "Project Elysium",
    genre: "Openworld Action RPG",
    image: "/images/project-elysium.png",
    description: "네온으로 빛나는 디스토피아 미래 도시를 배경으로 펼쳐지는 오픈월드 사이버펑크 RPG. 강력한 메카 슈트를 조종해 도시를 배후에서 조종하는 거대 기업의 음모를 파헤치세요.",
    platforms: ["Steam", "PS5", "Xbox Series X"],
    status: "In Development",
    link: "#"
  },
  {
    title: "Project Abyss",
    genre: "Dark Fantasy Soulslike",
    image: "/images/project-abyss.png",
    description: "멸망해가는 고대 신들의 성지를 무대로 한 극한의 난이도를 자랑하는 소울라이크 액션 RPG. 불사의 기사가 되어 타락한 고대의 수호신들을 봉인하고 질서를 찾으세요.",
    platforms: ["Steam", "PS5"],
    status: "Released",
    link: "#"
  }
];

// Careers data
const openPositions = [
  {
    title: "Game Client Programmer",
    department: "R&D Dev Team",
    type: "Full-Time",
    experience: "3+ years / Senior",
    techs: ["C++", "Unreal Engine 5", "PhysX"]
  },
  {
    title: "Technical Artist (TA)",
    department: "Art Team",
    type: "Full-Time",
    experience: "5+ years / Lead",
    techs: ["HLSL/GLSL", "Houdini", "UE5 Materials"]
  },
  {
    title: "3D Environment Artist",
    department: "Art Team",
    type: "Full-Time",
    experience: "Junior / Mid-level",
    techs: ["3ds Max / Maya", "Substance Painter", "ZBrush"]
  }
];
---

<Layout>
  <Header />

  <!-- Hero Section -->
  <section id="hero" class="hero-section">
    <div class="hero-bg-overlay"></div>
    <div class="container hero-content fade-in">
      <span class="hero-badge">PREMIUM INDIE GAME STUDIO</span>
      <h1 class="hero-title">WE SHAPE THE<br><span class="text-gradient">NEXT REALITY</span></h1>
      <p class="hero-desc">
        LOEF Studio는 한계를 극복하고 상상 이상의 세계를 게임으로 구현해내는 독립 게임 개발 스튜디오입니다. 독창적인 플레이와 압도적인 아트워크로 잊지 못할 여정을 선물합니다.
      </p>
      <div class="hero-actions">
        <a href="#games" class="btn-primary">Explore Games</a>
        <a href="#about" class="btn-secondary">Learn More</a>
      </div>
    </div>
    
    <!-- Animated scroll indicator -->
    <a href="#games" class="scroll-indicator" aria-label="Scroll down to games">
      <span class="mouse">
        <span class="wheel"></span>
      </span>
      <span class="arrow"></span>
    </a>
  </section>

  <!-- Games Section -->
  <section id="games" class="games-section reveal-section">
    <div class="container">
      <div class="section-header">
        <span class="subtitle">OUR PORTFOLIO</span>
        <h2 class="section-title">FEATURED <span class="text-gradient">PROJECTS</span></h2>
        <div class="section-line"></div>
      </div>
      
      <div class="games-grid">
        {featuredGames.map(game => (
          <GameCard {...game} />
        ))}
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="about-section reveal-section">
    <div class="container">
      <div class="about-grid">
        <div class="about-info">
          <span class="subtitle">WHO WE ARE</span>
          <h2 class="section-title">BEYOND <span class="text-gradient">PLAY</span></h2>
          <div class="section-line left"></div>
          <p class="about-desc">
            LOEF Studio는 2026년에 설립되어, 타협하지 않는 독창성과 최고 수준의 비주얼, 깊이 있는 스토리텔링을 바탕으로 프리미엄 인디 게임을 개발하고 있습니다. 
          </p>
          <p class="about-desc">
            우리는 게임이 단순한 오락적 가치를 넘어 플레이어의 감정을 흔들고 오래 기억에 남는 예술적 경험이 될 수 있다고 믿으며, 모든 개발 단계에서 완벽함을 지향합니다.
          </p>
        </div>
        
        <div class="about-values">
          <div class="value-card glass">
            <div class="value-icon cyan">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
            </div>
            <h3>Unlimited Creativity</h3>
            <p>기존 장르의 한계에 안주하지 않고, 독창적이고 새로운 게임 메커닉을 지속적으로 설계합니다.</p>
          </div>
          
          <div class="value-card glass">
            <div class="value-icon purple">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 12h20M12 2v20M20 20L4 4"/></svg>
            </div>
            <h3>Visual Masterpiece</h3>
            <p>차세대 엔진 활용 역량과 고유의 비주얼 정체성을 조화시켜 한 편의 애니메이션 같은 그래픽을 만듭니다.</p>
          </div>
          
          <div class="value-card glass">
            <div class="value-icon pink">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <h3>Community Centered</h3>
            <p>언제나 커뮤니티의 목소리에 경청하며 플레이어들과 긴밀하게 호흡하며 최선의 빌드를 업그레이드합니다.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Careers Section -->
  <section id="careers" class="careers-section reveal-section">
    <div class="container">
      <div class="section-header">
        <span class="subtitle">WE ARE HIRING</span>
        <h2 class="section-title">JOIN THE <span class="text-gradient">CREW</span></h2>
        <div class="section-line"></div>
        <p class="section-desc">
          LOEF Studio에서 자유롭게 도전하고, 영감을 주고받으며 세계 시장을 타겟으로 혁신적인 모험을 함께 설계할 유능한 전우들을 환영합니다.
        </p>
      </div>

      <div class="positions-list">
        {openPositions.map(pos => (
          <div class="position-item glass">
            <div class="position-header">
              <div class="position-title-group">
                <span class="position-dept">{pos.department}</span>
                <h3 class="position-title">{pos.title}</h3>
              </div>
              <div class="position-meta">
                <span class="pos-badge">{pos.type}</span>
                <span class="pos-badge">{pos.experience}</span>
              </div>
            </div>
            <div class="position-body">
              <div class="tech-tags">
                {pos.techs.map(tech => (
                  <span class="tech-tag">{tech}</span>
                ))}
              </div>
              <a href="mailto:recruit@loefstudio.com" class="btn-apply btn-secondary">Apply Now</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="contact-section reveal-section">
    <div class="container contact-container glass">
      <div class="contact-info-panel">
        <span class="subtitle">GET IN TOUCH</span>
        <h2 class="section-title">START A <span class="text-gradient">NEW MISSION</span></h2>
        <p class="contact-text">
          프로젝트 제안, 퍼블리싱 논의, 언론 취재 등 다양한 비즈니스 협업을 환영합니다. 아래 폼을 작성해 주시거나 메일로 바로 문의해 주세요.
        </p>
        <div class="contact-details">
          <div class="detail-item">
            <span class="icon">📧</span>
            <div>
              <h4>General Inquiry</h4>
              <p>contact@loefstudio.com</p>
            </div>
          </div>
          <div class="detail-item">
            <span class="icon">📍</span>
            <div>
              <h4>Studio Location</h4>
              <p>Seoul, Republic of Korea</p>
            </div>
          </div>
        </div>
      </div>
      
      <form class="contact-form" id="contactForm">
        <div class="form-group">
          <label for="name">이름 / 회사명</label>
          <input type="text" id="name" required placeholder="성함 혹은 사명을 적어주세요." />
        </div>
        <div class="form-group">
          <label for="email">이메일 주소</label>
          <input type="email" id="email" required placeholder="답변받으실 이메일을 입력하세요." />
        </div>
        <div class="form-group">
          <label for="message">문의 메시지</label>
          <textarea id="message" rows="5" required placeholder="상세한 문의 내용을 남겨주시면 빠르게 검토 후 회신 드리겠습니다."></textarea>
        </div>
        <button type="submit" class="btn-primary form-submit">Send Message</button>
      </form>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Hero Section Styling */
  .hero-section {
    position: relative;
    height: 100vh;
    min-height: 700px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-image: url('/images/hero-bg.png');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding-top: 80px;
  }

  .hero-bg-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, rgba(12, 13, 18, 0.4) 0%, hsl(var(--bg-dark)) 85%);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    max-width: 800px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-badge {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: hsl(var(--neon-cyan));
    text-shadow: var(--shadow-neon-cyan);
    text-transform: uppercase;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1.1;
  }

  .hero-desc {
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.7;
    max-width: 650px;
    text-align: center;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
  }

  /* Animated Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    z-index: 2;
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .scroll-indicator:hover {
    opacity: 1;
  }

  .mouse {
    width: 26px;
    height: 42px;
    border: 2px solid hsl(var(--text-primary));
    border-radius: 20px;
    display: flex;
    justify-content: center;
    padding-top: 6px;
  }

  .wheel {
    width: 4px;
    height: 8px;
    background-color: hsl(var(--neon-cyan));
    border-radius: 2px;
    animation: scrollWheel 2s infinite;
    box-shadow: var(--shadow-neon-cyan);
  }

  @keyframes scrollWheel {
    0% { transform: translateY(0); opacity: 1; }
    50% { transform: translateY(8px); opacity: 0.3; }
    100% { transform: translateY(0); opacity: 1; }
  }

  /* Sections Common Headers */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .subtitle {
    font-size: 0.8rem;
    font-weight: 800;
    color: hsl(var(--neon-purple));
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 900;
    margin-bottom: 1rem;
  }

  .section-line {
    width: 60px;
    height: 4px;
    background: var(--gradient-neon);
    margin: 0 auto;
    border-radius: 2px;
  }

  .section-line.left {
    margin: 0 0 1.5rem 0;
  }

  .section-desc {
    max-width: 600px;
    margin: 1.5rem auto 0 auto;
    color: hsl(var(--text-secondary));
  }

  /* Games Section */
  .games-section {
    padding: 8rem 0;
  }

  .games-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
    gap: 3rem;
  }

  @media (max-width: 768px) {
    .games-grid {
      grid-template-columns: 1fr;
    }
  }

  /* About Section */
  .about-section {
    padding: 8rem 0;
    background-color: hsl(240, 15%, 5%);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 1.8fr;
    gap: 5rem;
    align-items: center;
  }

  .about-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .about-desc {
    font-size: 1rem;
    line-height: 1.7;
  }

  .about-values {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .value-card {
    padding: 2rem;
    display: grid;
    grid-template-columns: 50px 1fr;
    gap: 1.5rem;
    align-items: flex-start;
    transition: transform var(--transition-fast);
  }

  .value-card:hover {
    transform: translateX(6px);
  }

  .value-icon {
    width: 50px;
    height: 50px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .value-icon.cyan {
    background-color: hsla(180, 100%, 50%, 0.1);
    color: hsl(var(--neon-cyan));
    border: 1px solid rgba(0, 255, 255, 0.2);
  }

  .value-icon.purple {
    background-color: hsla(280, 100%, 65%, 0.1);
    color: hsl(var(--neon-purple));
    border: 1px solid rgba(181, 69, 255, 0.2);
  }

  .value-icon.pink {
    background-color: hsla(325, 100%, 60%, 0.1);
    color: hsl(var(--neon-pink));
    border: 1px solid rgba(255, 51, 153, 0.2);
  }

  .value-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .value-card p {
    font-size: 0.9rem;
    color: hsl(var(--text-secondary));
  }

  @media (max-width: 992px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 3.5rem;
    }
  }

  /* Careers Section */
  .careers-section {
    padding: 8rem 0;
  }

  .positions-list {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .position-item {
    padding: 2rem;
    transition: var(--transition-fast);
  }

  .position-item:hover {
    border-color: hsl(var(--neon-purple));
    box-shadow: var(--shadow-neon-purple);
  }

  .position-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .position-dept {
    font-size: 0.75rem;
    font-weight: 700;
    color: hsl(var(--neon-cyan));
    text-transform: uppercase;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 0.25rem;
  }

  .position-title {
    font-size: 1.35rem;
    font-weight: 800;
  }

  .position-meta {
    display: flex;
    gap: 0.5rem;
  }

  .pos-badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    border-radius: 4px;
    background-color: hsla(240, 10%, 15%, 0.6);
    border: 1px solid var(--border-light);
    color: hsl(var(--text-secondary));
  }

  .position-body {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-light);
    padding-top: 1.25rem;
    flex-wrap: wrap;
    gap: 1.5rem;
  }

  .tech-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tech-tag {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    background: hsla(280, 100%, 65%, 0.05);
    border: 1px solid rgba(181, 69, 255, 0.15);
    color: hsl(var(--neon-purple));
    border-radius: 3px;
    font-weight: 600;
  }

  .btn-apply {
    padding: 0.5rem 1.5rem;
    font-size: 0.8rem;
    border-radius: 4px;
    text-transform: uppercase;
    font-weight: 700;
    text-decoration: none;
  }

  /* Contact Section */
  .contact-section {
    padding: 8rem 0;
    background-color: hsl(240, 15%, 4%);
  }

  .contact-container {
    display: grid;
    grid-template-columns: 1.2fr 1.8fr;
    gap: 4rem;
    padding: 4rem;
  }

  .contact-info-panel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-text {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .detail-item {
    display: flex;
    gap: 1.25rem;
    align-items: center;
  }

  .detail-item .icon {
    font-size: 1.5rem;
    width: 48px;
    height: 48px;
    background-color: hsla(240, 10%, 15%, 0.6);
    border: 1px solid var(--border-light);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .detail-item h4 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .detail-item p {
    font-size: 0.9rem;
    color: hsl(var(--text-secondary));
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .form-group label {
    font-family: 'Outfit', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: hsl(var(--text-secondary));
    letter-spacing: 0.05em;
  }

  .form-group input,
  .form-group textarea {
    padding: 0.9rem 1.25rem;
    background-color: hsla(240, 12%, 8%, 0.8);
    border: 1px solid var(--border-light);
    border-radius: 4px;
    color: hsl(var(--text-primary));
    font-family: inherit;
    font-size: 0.95rem;
    transition: var(--transition-fast);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: hsl(var(--neon-cyan));
    box-shadow: var(--shadow-neon-cyan);
  }

  .form-submit {
    align-self: flex-start;
  }

  @media (max-width: 992px) {
    .contact-container {
      grid-template-columns: 1fr;
      padding: 2.5rem;
    }
  }

  /* Scroll Reveal Anim Setup */
  .reveal-section {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .reveal-section.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  // Simple intersection observer for scroll reveal effects
  const revealSections = document.querySelectorAll('.reveal-section');
  
  const observerOptions = {
    root: null,
    threshold: 0.15,
    rootMargin: "0px 0px -50px 0px"
  };

  const observer = new IntersectionObserver((entries, obs) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        obs.unobserve(entry.target); // Trigger only once
      }
    });
  }, observerOptions);

  revealSections.forEach(section => {
    observer.observe(section);
  });

  // Mock Form Submit
  const contactForm = document.getElementById('contactForm');
  contactForm?.addEventListener('submit', (e) => {
    e.preventDefault();
